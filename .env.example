# SQL Trust Lens – Environment Variables
# Copy to .env and edit before running:  cp .env.example .env

# ── Application ─────────────────────────────────────────────────────────────

# Title shown in the browser tab and page header
APP_TITLE=SQL Trust Lens

# Port Streamlit listens on  (default 8501)
APP_PORT=8501

# Maximum number of queries kept in session history  (default 50)
MAX_HISTORY=50

# Show "did you mean" suggestions for invalid tables/columns (default true)
ENABLE_SUGGESTIONS=true

# ── Database ─────────────────────────────────────────────────────────────────

# Path to a persistent DuckDB file, or ":memory:" for an in-memory database.
# In-memory databases are reset on each restart; use a file path for persistence.
# Example: DB_PATH=./data/northwind.db
DB_PATH=:memory:

# ── LLM / SQL Generator ──────────────────────────────────────────────────────

# OpenRouter API key for real text-to-SQL generation.
# Get one at https://openrouter.ai – free tier available.
# When set, OpenRouter is used instead of the mock LLM.
OPENROUTER_API_KEY=

# OpenRouter API base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use via OpenRouter (default: google/gemini-2.5-flash-lite)
# Other options: google/gemini-2.5-flash, anthropic/claude-3-haiku, openai/gpt-4o-mini
LLM_MODEL=google/gemini-2.5-flash-lite

# Maximum retries for OpenRouter API calls on transient errors (default 2)
LLM_MAX_RETRIES=2

# Timeout in seconds for each OpenRouter API call (default 15)
LLM_TIMEOUT=15

# Maximum tokens to generate per LLM response (default 256)
LLM_MAX_TOKENS=256

# Sampling temperature for LLM responses — lower = more deterministic (default 0.1)
LLM_TEMPERATURE=0.1

# Context window size for llama-cpp-python inference (default 512)
LLAMA_CTX_SIZE=512

# Set to "false" to disable the keyword-based mock LLM.
# When disabled and no API key or Llama model is found, the app uses FALLBACK_SQL.
USE_MOCK_LLM=true

# Absolute path to a GGUF model file for llama-cpp-python (optional).
# Leave blank to use OpenRouter or the mock LLM.
# Example: LLAMA_MODEL_PATH=/models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
LLAMA_MODEL_PATH=

# SQL returned when all LLM backends are disabled/unavailable.
FALLBACK_SQL=SELECT * FROM users LIMIT 10

# ── Demo runner ───────────────────────────────────────────────────────────────

# Directory where demo.py writes output files (JSON, HTML, CSV)
OUTPUT_DIR=outputs
